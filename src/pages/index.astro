---
// --- Imports para la página de inicio ---

// 1. Componentes de Layout y de Astro (.astro) que SÍ se usan
import Layout from "../layouts/Layout.astro";
import Hero from "../components/landing/Hero.astro";
import About from "../components/landing/About.astro";
import Usuarios from "../components/landing/Usuarios.astro";
import Footer from "../components/landing/PiedePagina.astro";

// 2. Componentes de React (.jsx) que se van a renderizar
import DolarComponent from '../components/landing/DolarComponent.jsx';
import OtrasPaginas from '../components/landing/otrasPaginas.jsx'; // Asumo que es .jsx
import BancosdeVenezuela from '../components/landing/bancosdeVenezuelaReact.jsx'; // Asumo que es .jsx
import Login from '../components/landing/Login.jsx';
---

<Layout title="Dolar Al Dia Venezuela - Tasa de Cambio Actualizada">

  <Hero />
  
  <!-- Muestra tu componente principal de tasas de dólar -->
  <DolarComponent client:load />

  
  
  <!-- Muestra el resto de tus componentes interactivos -->
  <!-- <OtrasPaginas client:visible /> -->
  <BancosdeVenezuela client:visible />
  
  <!-- Componentes estáticos de Astro -->
  <Usuarios />
  <About />
  <Footer />
  
</Layout>