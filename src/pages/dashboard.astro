---
// src/pages/dashboard.astro

import Layout from '../layouts/Layout.astro';
import DashboardComponent from '../components/landing/Dashboard.jsx';
---
<Layout title="Mi Dashboard - Dolar Al Dia">

  <main>
    <DashboardComponent client:only="react" />
  </main>

  <script>
    // --- CORRECCIÓN AQUÍ ---
    // Usamos el alias '@' que apunta directamente a la carpeta 'src/'
    // Esta ruta funcionará sin importar dónde esté el archivo.
    import { isLoggedIn } from '@/stores/authStore';
    
    if (!isLoggedIn.get()) {
      window.location.href = '/'; 
    }
  </script>
</Layout>